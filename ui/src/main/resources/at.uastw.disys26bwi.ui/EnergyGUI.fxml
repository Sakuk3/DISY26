<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" spacing="15.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="at.uastw.disys26bwi.ui.EnergyController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <!-- Sektion 1: Community Status -->
        <GridPane vgap="10.0" hgap="10.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Text text="Community Pool" strokeType="OUTSIDE" strokeWidth="0.0">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Text>
                <Label fx:id="communityPoolUsed" text="ComPool Percent used" GridPane.columnIndex="1" />

                <Text text="Grid Portion" strokeType="OUTSIDE" strokeWidth="0.0" GridPane.rowIndex="1" />
                <Label fx:id="gridPortion" text="Grid Portion Percentage" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Button fx:id="buttonRefresh" mnemonicParsing="false" onAction="#onRefreshButtonClick" prefWidth="100.0" text="Refresh" GridPane.rowIndex="2" />
            </children>
        </GridPane>

        <Separator prefWidth="200.0" />

        <!-- Sektion 2: Zeitraum Auswahl -->
        <GridPane vgap="10.0" hgap="10.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Text text="Start" strokeType="OUTSIDE" strokeWidth="0.0" />
                <DatePicker id="startDate" fx:id="startDate" maxWidth="Infinity" GridPane.columnIndex="1" />

                <Text text="End" strokeType="OUTSIDE" strokeWidth="0.0" GridPane.rowIndex="1" />
                <DatePicker id="endDate" fx:id="endDate" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Button fx:id="buttonShowData" mnemonicParsing="false" onAction="#onShowButtonClick" prefWidth="100.0" text="Show Data" GridPane.rowIndex="2" />
            </children>
        </GridPane>

        <Separator prefWidth="200.0" />

        <!-- Sektion 3: Verbrauchsdaten -->
        <GridPane vgap="8.0" hgap="10.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="140.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="130.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Text text="Community Produced" strokeType="OUTSIDE" strokeWidth="0.0" />
                <Label fx:id="communityProduced" text="Com Prod Kwh" GridPane.columnIndex="1" />

                <Text text="Community Used" strokeType="OUTSIDE" strokeWidth="0.0" GridPane.rowIndex="1" />
                <Label fx:id="communityUsed" text="Com Used Kwh" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Text text="Grid used" strokeType="OUTSIDE" strokeWidth="0.0" GridPane.rowIndex="2" />
                <Label fx:id="gridUsed" text="Grid Used Kwh" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
        </GridPane>

        <Separator prefWidth="200.0" />
    </children>
</VBox>